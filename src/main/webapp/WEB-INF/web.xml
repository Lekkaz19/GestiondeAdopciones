<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <display-name>Sistema de Adopciones - API REST</display-name>

    <!-- Servlet para Mascotas -->
    <servlet>
        <servlet-name>MascotaServlet</servlet-name>
        <servlet-class>com.refugio.controlador.MascotaServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>MascotaServlet</servlet-name>
        <url-pattern>/api/mascotas</url-pattern>
    </servlet-mapping>

    <!-- Servlet para Adopciones -->
    <servlet>
        <servlet-name>AdopcionServlet</servlet-name>
        <servlet-class>com.refugio.controlador.AdopcionServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdopcionServlet</servlet-name>
        <url-pattern>/api/adopciones</url-pattern>
    </servlet-mapping>

</web-app>
